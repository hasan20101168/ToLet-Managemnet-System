<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>Owner Dashboard | To-Let Pro</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  >

  <link rel="stylesheet" href="/css/owner.css">
</head>

<body>

<div class="dashboard-layout">

  <!-- ================= SIDEBAR ================= -->
  <aside class="sidebar">

    <div class="sidebar-top">

      <div class="brand">

        <div class="brand-logo">
          <i class="bi bi-buildings"></i>
        </div>

        <div>
          <h4>To-Let Pro</h4>
          <p>Management Suite</p>
        </div>

      </div>

      <nav class="sidebar-nav">

        <a href="/rentals/owner/dashboard" class="nav-item active">
          <i class="bi bi-grid-1x2"></i>
          Dashboard
        </a>

        <a href="/rentals/new" class="nav-item">
          <i class="bi bi-building"></i>
          Properties
        </a>

        <a href="#" class="nav-item">
          <i class="bi bi-cash-stack"></i>
          Finance
        </a>

        <a href="#" class="nav-item">
          <i class="bi bi-people"></i>
          Tenants
        </a>

        <a href="/messages/owner/inbox" class="nav-item">
          <i class="bi bi-chat-dots"></i>
          Messages
        </a>

      </nav>

    </div>

    <!-- bottom -->
    <div class="sidebar-bottom">

      <div class="profile-box">

        <div class="profile-avatar">
          <i class="bi bi-person-fill"></i>
        </div>

        <div class="profile-info">
          <h6><%= currentUser?.name || "Owner" %></h6>
          <p>Property Owner</p>
        </div>

      </div>

      <form action="/logout" method="POST" class="logout-form">
        <button type="submit" class="logout-btn">
          <i class="bi bi-box-arrow-right"></i>
          Logout
        </button>
      </form>

    </div>

  </aside>

  <!-- ================= MAIN ================= -->
  <main class="dashboard-main">

    <!-- TOPBAR -->
    <div class="topbar">

      <div class="search-box">
        <i class="bi bi-search"></i>

        <input
          type="text"
          placeholder="Search properties, tenants or invoices..."
        >
      </div>

      <div class="topbar-actions">

        <button class="btn-filter">
          <i class="bi bi-calendar3"></i>
          Last 30 Days
        </button>

        <button class="btn-export">
          <i class="bi bi-download"></i>
          Export Report
        </button>

      </div>

    </div>

    <!-- ================= PAGE HEADER ================= -->
    <div class="page-header">

      <div>
        <h2>Executive Overview</h2>
        <p>
          Real-time performance metrics for your rental portfolio.
        </p>
      </div>

      <a href="/rentals/new" class="btn-add-property">
        <i class="bi bi-plus-lg"></i>
        Add Property
      </a>

    </div>

    <!-- ================= STATS ================= -->
    <section class="stats-grid">

      <!-- CARD -->
      <div class="analytics-card">

        <div class="analytics-top">
          <p>Total Revenue</p>

          <div class="analytics-icon revenue">
            <i class="bi bi-cash-stack"></i>
          </div>
        </div>

        <h3>
          ৳<%= analytics.totalRentValue.toLocaleString() %>
        </h3>

        <span class="analytics-badge positive">
          +8.2% vs last month
        </span>

      </div>

      <!-- CARD -->
      <div class="analytics-card">

        <div class="analytics-top">
          <p>Occupancy Rate</p>

          <div class="analytics-icon occupancy">
            <i class="bi bi-pie-chart"></i>
          </div>
        </div>

        <h3>94.2%</h3>

        <span class="analytics-muted">
          <%= analytics.availableProperties %> units available
        </span>

      </div>

      <!-- CARD -->
      <div class="analytics-card">

        <div class="analytics-top">
          <p>Active Listings</p>

          <div class="analytics-icon listings">
            <i class="bi bi-buildings"></i>
          </div>
        </div>

        <h3>
          <%= analytics.totalProperties %>
        </h3>

        <span class="analytics-muted">
          Updated in real time
        </span>

      </div>

      <!-- CARD -->
      <div class="analytics-card">

        <div class="analytics-top">
          <p>Average Rent</p>

          <div class="analytics-icon avg">
            <i class="bi bi-bar-chart-fill"></i>
          </div>
        </div>

        <h3>
          ৳<%= analytics.averageRent.toLocaleString() %>
        </h3>

        <span class="analytics-muted">
          Market performance
        </span>

      </div>

    </section>

    <!-- ================= GRID ================= -->
    <div class="dashboard-grid">

      <!-- ================= LEFT ================= -->
      <div class="dashboard-left">

        <!-- CHART -->
        <div class="dashboard-card chart-card">

          <div class="card-header-custom">

            <div>
              <h5>Revenue Trends</h5>
              <p>Monthly rental income overview</p>
            </div>

            <div class="legend-group">

              <span class="legend-item">
                <span class="dot dark"></span>
                Income
              </span>

              <span class="legend-item">
                <span class="dot light"></span>
                Expenses
              </span>

            </div>

          </div>

          <!-- Fake graph -->
          <div class="chart-placeholder">

            <div class="graph-lines"></div>

            <div class="graph-months">
              <span>JAN</span>
              <span>FEB</span>
              <span>MAR</span>
              <span>APR</span>
              <span>MAY</span>
              <span>JUN</span>
            </div>

          </div>

        </div>

        <!-- PROPERTY LIST -->
        <div class="dashboard-card properties-card">

          <div class="card-header-custom">

            <div>
              <h5>My Properties</h5>
              <p>
                Manage and monitor all property listings
              </p>
            </div>

          </div>

          <% if (rentals.length === 0) { %>

            <div class="empty-state">

              <i class="bi bi-house-add"></i>

              <h4>No properties found</h4>

              <p>
                Start by adding your first rental property.
              </p>

              <a href="/rentals/new" class="btn-add-property">
                Add First Property
              </a>

            </div>

          <% } else { %>

            <div class="properties-grid">

              <% rentals.forEach(r => { %>

                <div class="property-card">

                  <div class="property-image-wrap">

                    <% if (r.image && r.image.url) { %>

                      <img
                        src="<%= r.image.url %>"
                        class="property-image"
                        alt="<%= r.name %>"
                      >

                    <% } else { %>

                      <div class="property-placeholder">
                        <i class="bi bi-image"></i>
                      </div>

                    <% } %>

                    <span class="property-price">
                      ৳<%= Number(r.rentPrice).toLocaleString() %>
                    </span>

                  </div>

                  <div class="property-content">

                    <h5><%= r.name %></h5>

                    <p class="property-location">
                      <i class="bi bi-geo-alt"></i>
                      <%= r.address %>
                    </p>

                    <div class="property-meta">

                      <span>
                        <i class="bi bi-door-closed"></i>
                        <%= r.beds || 0 %> Beds
                      </span>

                      <span>
                        <i class="bi bi-droplet"></i>
                        <%= r.baths || 0 %> Baths
                      </span>

                    </div>

                    <div class="property-actions">

                      <a
                        href="/rentals/<%= r._id %>"
                        class="btn-property view"
                      >
                        View
                      </a>

                      <a
                        href="/rentals/<%= r._id %>/edit"
                        class="btn-property edit"
                      >
                        Edit
                      </a>

                      <form
                        action="/rentals/<%= r._id %>?_method=DELETE"
                        method="POST"
                        onsubmit="return confirm('Delete this rental?')"
                      >

                        <button
                          type="submit"
                          class="btn-property delete"
                        >
                          Delete
                        </button>

                      </form>

                    </div>

                  </div>

                </div>

              <% }) %>

            </div>

          <% } %>

        </div>

      </div>

      <!-- ================= RIGHT ================= -->
      <div class="dashboard-right">

        <!-- QUICK ACTIONS -->
        <div class="dashboard-card">

          <div class="card-header-custom">

            <div>
              <h5>Quick Actions</h5>
              <p>Manage your workflow faster</p>
            </div>

          </div>

          <div class="quick-actions">

            <a href="/rentals/new" class="quick-btn">
              <i class="bi bi-plus-circle"></i>
              Add Listing
            </a>

            <a href="/messages" class="quick-btn">
              <i class="bi bi-chat-dots"></i>
              Messages
            </a>

            <a href="/rentals" class="quick-btn">
              <i class="bi bi-house"></i>
              View Listings
            </a>

          </div>

        </div>

        <!-- PORTFOLIO -->
        <div class="dashboard-card portfolio-card">

          <% if (rentals.length > 0 && rentals[0].image) { %>

            <img
              src="<%= rentals[0].image.url %>"
              class="portfolio-image"
            >

          <% } %>

          <div class="portfolio-overlay">

            <span class="portfolio-badge">
              98% Occupancy
            </span>

            <h4>
              <%= rentals.length > 0 ? rentals[0].name : "Portfolio" %>
            </h4>

            <p>Premium Property Collection</p>

          </div>

        </div>

        <!-- HEALTH -->
        <div class="dashboard-card">

          <div class="card-header-custom">

            <div>
              <h5>Portfolio Health</h5>
            </div>

            <i class="bi bi-stars health-icon"></i>

          </div>

          <p class="health-text">

            Your portfolio is performing strongly with above-average
            rental demand and stable occupancy rates.

          </p>

          <div class="health-rating">

            <span>Overall Rating</span>

            <div class="stars">
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-half"></i>
            </div>

          </div>

        </div>

      </div>

    </div>

  </main>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>