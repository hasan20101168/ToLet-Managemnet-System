<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Owner Dashboard | My Rentals</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <!-- Inter font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <link rel="stylesheet" href="/css/owner.css">
</head>
<body>

  <%- include("../partials/navbar") %>

  <!-- Hero -->
  <header class="hero">
    <div class="container">
      <span class="badge-soft mb-3 d-inline-block">
        <i class="bi bi-houses-fill me-1"></i>
        <%= rentals.length %> propert<%= rentals.length === 1 ? 'y' : 'ies' %> listed
      </span>
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-end gap-3">
        <div>
          <h1>My Rentals</h1>
          <p class="mb-0">Manage your property listings, track availability and keep details up to date.</p>
        </div>
        <a href="/rentals/new" class="btn-add">
          <i class="bi bi-plus-lg me-1"></i> Add New Property
        </a>
      </div>
    </div>
  </header>

  <!-- Main -->
  <main class="main-wrap">
    <div class="container">

      <% if (rentals.length === 0) { %>
        <div class="empty-card">
          <i class="bi bi-house-add"></i>
          <h5 class="fw-semibold mb-1">No rentals found</h5>
          <p class="text-muted mb-3">Start by adding your first property to begin attracting tenants.</p>
          <a href="/rentals/new" class="btn-action btn-view d-inline-flex" style="flex:0 0 auto;">
            <i class="bi bi-plus-lg"></i> Add your first listing
          </a>
        </div>
      <% } else { %>

        <div class="rental-grid">
          <% rentals.forEach(r => { %>
            <article class="rental-card">
              <div class="rental-media">
                <% if (r.image && r.image.url) { %>
                  <img src="<%= r.image.url %>" alt="<%= r.name %>" loading="lazy">
                <% } else { %>
                  <div class="no-image"><i class="bi bi-image me-1"></i> No image</div>
                <% } %>

                <% if (r.type) { %>
                  <span class="chip-type"><%= r.type %></span>
                <% } %>
                <span class="chip-price">৳<%= Number(r.rentPrice).toLocaleString() %></span>
              </div>

              <div class="rental-body">
                <h3 class="rental-title"><%= r.name %></h3>
                <p class="rental-address">
                  <i class="bi bi-geo-alt-fill"></i>
                  <span><%= r.address %></span>
                </p>

                <div class="rental-meta">
                  <span><i class="bi bi-door-closed-fill"></i> <%= r.beds || 0 %> Beds</span>
                  <span><i class="bi bi-droplet-fill"></i> <%= r.baths || 0 %> Baths</span>
                  <span><i class="bi bi-rulers"></i> <%= r.squareFeet || 0 %> sqft</span>
                </div>

                <div class="rental-actions">
                  <a href="/rentals/<%= r._id %>" class="btn-action btn-view">
                    <i class="bi bi-eye-fill"></i> View
                  </a>
                  <a href="/rentals/<%= r._id %>/edit" class="btn-action btn-edit">
                    <i class="bi bi-pencil-fill"></i> Edit
                  </a>
                  <form class="delete-form" action="/rentals/<%= r._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this rental?');">
                    <button type="submit" class="btn-action btn-delete-icon" title="Delete">
                      <i class="bi bi-trash-fill"></i>
                    </button>
                  </form>
                </div>
              </div>
            </article>
          <% }) %>
        </div>

      <% } %>

    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
