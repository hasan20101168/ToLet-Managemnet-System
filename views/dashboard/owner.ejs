<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Owner Dashboard</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<%- include("../partials/navbar") %>
<body class="bg-light">

<div class="container mt-5">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🏠 My Rentals</h2>
    <a href="/rentals/new" class="btn btn-primary">+ Add New</a>
  </div>

  <!-- Empty State -->
  <% if (rentals.length === 0) { %>
    <div class="alert alert-info">
      No rentals found. Start by adding your first property.
    </div>
  <% } %>

  <!-- Rentals List -->
  <div class="row g-4">

    <% rentals.forEach(r => { %>
      <div class="col-md-4">
        <div class="card shadow-sm h-100">

          <!-- Image -->
          <% if (r.image && r.image.url) { %>
            <img src="<%= r.image.url %>" class="card-img-top" style="height:200px; object-fit:cover;">
          <% } else { %>
            <img src="https://via.placeholder.com/400x200?text=No+Image" class="card-img-top">
          <% } %>

          <div class="card-body d-flex flex-column">

            <h5 class="card-title"><%= r.name %></h5>

            <p class="text-muted small mb-2">
              📍 <%= r.address %>
            </p>

            <p class="fw-bold text-primary mb-3">
              ৳ <%= r.rentPrice %>
            </p>

            <!-- Actions -->
            <div class="mt-auto d-flex justify-content-between">

              <a href="/rentals/<%= r._id %>" class="btn btn-sm btn-outline-primary">
                View
              </a>

              <a href="/rentals/<%= r._id %>/edit" class="btn btn-sm btn-warning">
                Edit
              </a>

              <!-- 🔥 DELETE BUTTON -->
              <form 
                action="/rentals/<%= r._id %>?_method=DELETE" 
                method="POST"
                onsubmit="return confirm('Are you sure you want to delete this rental?');"
              >
                <button class="btn btn-sm btn-danger">
                  Delete
                </button>
              </form>

            </div>

          </div>
        </div>
      </div>
    <% }) %>

  </div>

</div>

</body>
</html>