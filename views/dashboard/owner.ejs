      </div>

      <!-- ================= RIGHT ================= -->
      <div class="dashboard-right">

        <!-- QUICK ACTIONS -->
        <div class="dashboard-card maintenance-card">

  <div class="card-header-custom maintenance-header">

    <h5>Priority Maintenance</h5>

    <a href="#" class="view-all-link">
      View All
    </a>

  </div>

  <div class="maintenance-list">

    <% if (maintenanceRequests.length === 0) { %>

      <p style="padding:20px;">
        No maintenance requests found.
      </p>

    <% } %>

    <% maintenanceRequests.forEach(req => { %>

      <div class="maintenance-item">

        <div class="maintenance-icon
          <%= req.status === 'completed'
            ? 'primary'
            : req.status === 'in-progress'
            ? 'warning'
            : 'danger'
          %>
        ">

          <i class="bi bi-tools"></i>

        </div>

        <div class="maintenance-content">

          <div class="maintenance-top">

            <div>

              <h6>
                <%= req.title %>
              </h6>

              <p>
                <%= req.rental?.name || "Property" %>
              </p>

            </div>

            <span class="maintenance-time">

              <%= new Date(req.createdAt).toLocaleDateString() %>

            </span>

          </div>

          <div class="maintenance-tags">

            <span class="tag
              <%= req.status === 'completed'
                ? 'normal'
                : req.status === 'in-progress'
                ? 'high'
                : 'urgent'
              %>
            ">

              <%= req.status %>

            </span>

          </div>

        </div>

      </div>

    <% }) %>

  </div>

</div>

        <!-- PORTFOLIO -->
         <div class="portfolio-health-row">
        <div class="dashboard-card portfolio-card">

          <% if (rentals.length > 0 && rentals[0].image) { %>

            <img
              src="<%= rentals[0].image.url %>"
              class="portfolio-image"
            >

          <% } %>

          <div class="portfolio-overlay">

            <span class="portfolio-badge">
              98% Occupancy
            </span>

            <h4>
              <%= rentals.length > 0 ? rentals[0].name : "Portfolio" %>
            </h4>

            <p>Premium Property Collection</p>

          </div>

        </div>

        <!-- HEALTH -->
        <div class="dashboard-card">

          <div class="card-header-custom">

            <div>
              <h5>Portfolio Health</h5>
            </div>

            <i class="bi bi-stars health-icon"></i>

          </div>

          <p class="health-text">

            Your portfolio is performing strongly with above-average
            rental demand and stable occupancy rates.

          </p>

          <div class="health-rating">

            <span>Overall Rating</span>

            <div class="stars">
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-fill"></i>
              <i class="bi bi-star-half"></i>
            </div>

          </div>

        </div>
        </div>

      </div>

    </div>

  </main>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>