<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>Owner Dashboard | To-Let </title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  >

  <link rel="stylesheet" href="/css/owner.css">
</head>

<body>

<div class="dashboard-layout">

  <%- include("../partials/sidebar") %>

  <!-- ================= MAIN ================= -->
  <main class="dashboard-main">

    <!-- TOPBAR -->
    <div class="topbar">

      <div class="search-box">
        <i class="bi bi-search"></i>

        <input
          type="text"
          placeholder="Search properties, tenants or invoices..."
        >
      </div>

      <!-- <div class="topbar-actions">

        <button class="btn-filter">
          <i class="bi bi-calendar3"></i>
          Last 30 Days
        </button>

        <button class="btn-export">
          <i class="bi bi-download"></i>
          Export Report
        </button>

      </div> -->

    </div>

    <!-- ================= PAGE HEADER ================= -->
    <div class="page-header">

      <div>
        <h2>Executive Overview</h2>
        <p>
          Real-time performance metrics for your rental portfolio.
        </p>
      </div>

      <div class="topbar-actions">

        <button class="btn-filter">
          <i class="bi bi-calendar3"></i>
          Last 30 Days
        </button>

        <button class="btn-export">
          <i class="bi bi-download"></i>
          Export Report
        </button>

      </div>

    </div>

    <!-- ================= STATS ================= -->
    <section class="stats-grid">

      <!-- CARD -->
      <div class="analytics-card">

        <div class="analytics-top">
          <p>Total Revenue</p>

          <div class="analytics-icon revenue">
            <i class="bi bi-cash-stack"></i>
          </div>
        </div>

        <h3>
          ৳<%= analytics.totalRentValue.toLocaleString() %>
        </h3>

        <span class="analytics-badge positive">
          +8.2% vs last month
        </span>

      </div>

      <!-- CARD -->
      <div class="analytics-card">

        <div class="analytics-top">
          <p>Occupancy Rate</p>

          <div class="analytics-icon occupancy">
            <i class="bi bi-pie-chart"></i>
          </div>
        </div>

        <h3>94.2%</h3>

        <span class="analytics-muted">
          <%= analytics.availableProperties %> units available
        </span>

      </div>

      <!-- CARD -->
      <div class="analytics-card">

        <div class="analytics-top">
          <p>Active Listings</p>

          <div class="analytics-icon listings">
            <i class="bi bi-buildings"></i>
          </div>
        </div>

        <h3>
          <%= analytics.totalProperties %>
        </h3>

        <span class="analytics-muted">
          Updated in real time
        </span>

      </div>

      <!-- CARD -->
      <div class="analytics-card">

        <div class="analytics-top">
          <p>Average Rent</p>

          <div class="analytics-icon avg">
            <i class="bi bi-bar-chart-fill"></i>
          </div>
        </div>

        <h3>
          ৳<%= analytics.averageRent.toLocaleString() %>
        </h3>

        <span class="analytics-muted">
          Market performance
        </span>

      </div>

    </section>

    <!-- ================= GRID ================= -->
    <div class="dashboard-grid">

      <!-- ================= LEFT ================= -->
      <div class="dashboard-left">

        <!-- CHART -->
        <div class="dashboard-card chart-card">

          <div class="card-header-custom">

            <div>
              <h5>Revenue Trends</h5>
              <p>Monthly rental income overview</p>
            </div>

            <div class="legend-group">

              <span class="legend-item">
                <span class="dot dark"></span>
                Income
              </span>

              <span class="legend-item">
                <span class="dot light"></span>
                Expenses
              </span>

            </div>

          </div>

          <!-- Fake graph -->
          <div class="chart-placeholder">

            <div class="graph-lines"></div>

            <div class="graph-months">
              <span>JAN</span>
              <span>FEB</span>
              <span>MAR</span>
              <span>APR</span>
              <span>MAY</span>
              <span>JUN</span>
            </div>

          </div>

        </div>

                <!-- UPCOMING LEASE EXPIRATIONS -->
<div class="dashboard-card lease-card">

  <div class="lease-card-header">
    <h5>Upcoming lease expirations</h5>
    <span class="lease-count-badge">3 expiring soon</span>
  </div>

  <table class="lease-table">
    <thead>
      <tr>
        <th>Tenant</th>
        <th>Unit</th>
        <th>Expiry</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="tenant-name">Sarah Jenkins</td>
        <td class="unit-name">Skyline Penthouse 2</td>
        <td><span class="expiry-dot dot-urgent"></span> Oct 12, 2023</td>
        <td><button class="action-btn btn-notice">Send notice</button></td>
      </tr>
      <tr>
        <td class="tenant-name">Marcus Thorne</td>
        <td class="unit-name">Crestview Studio 14</td>
        <td><span class="expiry-dot dot-soon"></span> Oct 28, 2023</td>
        <td><button class="action-btn btn-renew">Renew</button></td>
      </tr>
      <tr>
        <td class="tenant-name">Evelyn Rodriguez</td>
        <td class="unit-name">Oak Tower 202</td>
        <td><span class="expiry-dot dot-soon"></span> Nov 04, 2023</td>
        <td><button class="action-btn btn-notice">Send notice</button></td>
      </tr>
      <tr>
        <td class="tenant-name">Daniel Park</td>
        <td class="unit-name">Harborview Loft 5B</td>
        <td><span class="expiry-dot dot-ok"></span> Nov 18, 2023</td>
        <td><button class="action-btn btn-review">Review</button></td>
      </tr>
    </tbody>
  </table>

</div>

        <!-- PROPERTY LIST -->
