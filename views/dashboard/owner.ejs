<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Owner Dashboard | My Rentals</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <!-- Inter font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
  --background: #fbf9f5;
  --foreground: #181f2b;
  --card: #ffffff;
  --muted: #f1ede6;
  --muted-foreground: #6b7280;
  --border: #e6e0d6;
  --primary: #1e8a5f;
  --primary-glow: #28b97f;
  --primary-foreground: #fbf9f5;
  --accent: #f08a2c;
  --accent-2: #e76a32;
  --destructive: #dc3545;
  --radius: 0.85rem;

  --gradient-hero: linear-gradient(135deg, #1e8a5f 0%, #20a596 100%);
  --gradient-card: linear-gradient(180deg, #ffffff 0%, #fbf8f2 100%);
  --gradient-price: linear-gradient(135deg, #f08a2c, #e85a3a);

  --shadow-sm: 0 1px 2px 0 rgba(24,31,43,.04);
  --shadow-md: 0 4px 16px -4px rgba(24,31,43,.08);
  --shadow-lg: 0 12px 32px -8px rgba(24,31,43,.14);
  --shadow-glow: 0 8px 24px -6px rgba(240,138,44,.45);
  --transition: all .3s cubic-bezier(.4,0,.2,1);
}

* { box-sizing: border-box; }

body {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  background: var(--background);
  color: var(--foreground);
  -webkit-font-smoothing: antialiased;
}

/* Container alignment */
.container {
  max-width: 1200px;
}

/* Hero */
.hero {
  background: var(--gradient-hero);
  color: var(--primary-foreground);
  padding: 4rem 0 6rem;
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 80% 20%, rgba(255,255,255,.12), transparent 50%);
  pointer-events: none;   /* 🔥 FIX: allows clicking through */
}
.hero .container {
  position: relative;
  z-index: 2;
}
.hero h1 {
  font-weight: 800;
  font-size: clamp(2rem, 4vw, 3rem);
  margin-bottom: .5rem;
}
.hero p { opacity: .9; max-width: 36rem; }

.badge-soft {
  background: rgba(255,255,255,.18);
  color: #fff;
  backdrop-filter: blur(8px);
  padding: .5rem .85rem;
  border-radius: 999px;
  font-size: .8rem;
}

.btn-add {
  background: #fff;
  color: var(--primary);
  font-weight: 600;
  border-radius: .75rem;
  padding: .65rem 1.15rem;
  box-shadow: var(--shadow-md);
}
.btn-add:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

/* 🔥 FIX: Push cards slightly lower */
.main-wrap {
  margin-top: 3.5rem;   /* reduced overlap */
  padding-bottom: 5rem;
  position: relative;
  z-index: 2;
}

/* Empty */
.empty-card {
  background: var(--card);
  border: 1px dashed var(--border);
  border-radius: var(--radius);
  padding: 4rem 1.5rem;
  text-align: center;
}

/* 🔥 FIX: Better grid spacing & alignment */
.rental-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.75rem;
  margin-top: 1.5rem;   /* pushes cards down */
}

/* 🔥 FIX: Equal height cards */
.rental-card {
  background: var(--gradient-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  transition: var(--transition);
  display: flex;
  flex-direction: column;
  height: 100%;
}
.rental-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
}

/* Image */
.rental-media {
  position: relative;
  aspect-ratio: 4/3;
  overflow: hidden;
  background: var(--muted);
}
.rental-media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Badges */
.chip-type {
  position: absolute;
  top: .85rem;
  left: .85rem;
  background: rgba(255,255,255,.92);
  padding: .35rem .7rem;
  border-radius: 999px;
  font-size: .72rem;
}

.chip-price {
  position: absolute;
  top: .85rem;
  right: .85rem;
  background: var(--gradient-price);
  color: #fff;
  padding: .4rem .85rem;
  border-radius: 999px;
}

/* 🔥 FIX: Perfect vertical alignment */
.rental-body {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  flex: 1;
  justify-content: space-between;
}

.rental-title {
  font-size: 1.05rem;
  font-weight: 600;
}

.rental-address {
  font-size: .85rem;
  color: var(--muted-foreground);
  margin-bottom: 1rem;
}

/* Meta */
.rental-meta {
  display: flex;
  justify-content: space-between;
  padding: .75rem 0;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  margin-bottom: 1rem;
  font-size: .85rem;
}

/* Actions */
.rental-actions {
  display: flex;
  gap: .5rem;
  margin-top: auto;
}

.btn-action {
  border-radius: .55rem;
  padding: .5rem .8rem;
  font-size: .82rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .35rem;
  text-decoration: none;
}

.btn-view {
  background: var(--primary);
  color: #fff;
  flex: 1;
}

.btn-edit {
  background: var(--muted);
}

.btn-delete-icon {
  color: var(--destructive);
}

/* Mobile */
@media (max-width: 576px) {
  .hero {
    padding: 2.5rem 0 5rem;
  }
  .rental-grid {
    grid-template-columns: 1fr;
  }
}
  </style>
</head>
<body>

  <%- include("../partials/navbar") %>

  <!-- Hero -->
  <header class="hero">
    <div class="container">
      <span class="badge-soft mb-3 d-inline-block">
        <i class="bi bi-houses-fill me-1"></i>
        <%= rentals.length %> propert<%= rentals.length === 1 ? 'y' : 'ies' %> listed
      </span>
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-end gap-3">
        <div>
          <h1>My Rentals</h1>
          <p class="mb-0">Manage your property listings, track availability and keep details up to date.</p>
        </div>
        <a href="/rentals/new" class="btn-add">
          <i class="bi bi-plus-lg me-1"></i> Add New Property
        </a>
      </div>
    </div>
  </header>

  <!-- Main -->
  <main class="main-wrap">
    <div class="container">

      <% if (rentals.length === 0) { %>
        <div class="empty-card">
          <i class="bi bi-house-add"></i>
          <h5 class="fw-semibold mb-1">No rentals found</h5>
          <p class="text-muted mb-3">Start by adding your first property to begin attracting tenants.</p>
          <a href="/rentals/new" class="btn-action btn-view d-inline-flex" style="flex:0 0 auto;">
            <i class="bi bi-plus-lg"></i> Add your first listing
          </a>
        </div>
      <% } else { %>

        <div class="rental-grid">
          <% rentals.forEach(r => { %>
            <article class="rental-card">
              <div class="rental-media">
                <% if (r.image && r.image.url) { %>
                  <img src="<%= r.image.url %>" alt="<%= r.name %>" loading="lazy">
                <% } else { %>
                  <div class="no-image"><i class="bi bi-image me-1"></i> No image</div>
                <% } %>

                <% if (r.type) { %>
                  <span class="chip-type"><%= r.type %></span>
                <% } %>
                <span class="chip-price">৳<%= Number(r.rentPrice).toLocaleString() %></span>
              </div>

              <div class="rental-body">
                <h3 class="rental-title"><%= r.name %></h3>
                <p class="rental-address">
                  <i class="bi bi-geo-alt-fill"></i>
                  <span><%= r.address %></span>
                </p>

                <div class="rental-meta">
                  <span><i class="bi bi-door-closed-fill"></i> <%= r.beds || 0 %> Beds</span>
                  <span><i class="bi bi-droplet-fill"></i> <%= r.baths || 0 %> Baths</span>
                  <span><i class="bi bi-rulers"></i> <%= r.squareFeet || 0 %> sqft</span>
                </div>

                <div class="rental-actions">
                  <a href="/rentals/<%= r._id %>" class="btn-action btn-view">
                    <i class="bi bi-eye-fill"></i> View
                  </a>
                  <a href="/rentals/<%= r._id %>/edit" class="btn-action btn-edit">
                    <i class="bi bi-pencil-fill"></i> Edit
                  </a>
                  <form class="delete-form" action="/rentals/<%= r._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this rental?');">
                    <button type="submit" class="btn-action btn-delete-icon" title="Delete">
                      <i class="bi bi-trash-fill"></i>
                    </button>
                  </form>
                </div>
              </div>
            </article>
          <% }) %>
        </div>

      <% } %>

    </div>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
