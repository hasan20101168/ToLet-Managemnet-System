<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Properties | To-Let Pro</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <link rel="stylesheet" href="/css/properties.css">
  <link rel="stylesheet" href="/css/owner.css">
</head>

<body>

<div class="dashboard-layout">

  <%- include("../partials/sidebar") %>

  <main class="main-content">

    <!-- Topbar -->
    <div class="topbar">

      <div class="search-box">
        <i class="bi bi-search"></i>

        <input type="text"
               placeholder="Search properties, addresses...">
      </div>

      <div class="top-actions">

        <button class="btn-light-ui">
          <i class="bi bi-download"></i>
          Export List
        </button>

        <a href="/rentals/new" class="btn-dark-ui">
          <i class="bi bi-plus-lg"></i>
          Add Property
        </a>

      </div>

    </div>

    <!-- Header -->
    <div class="page-header">

      <div>
        <h1>Property Inventory</h1>

        <p>
          Manage and track
          <%= rentals.length %>
          active properties across your portfolio.
        </p>
      </div>

    </div>

    <!-- Table -->
    <div class="property-table-card">

      <table class="property-table">

        <thead>
          <tr>
            <th>PROPERTY DETAILS</th>
            <th>TYPE</th>
            <th>BEDS</th>
            <th>STATUS</th>
            <th>MONTHLY RENT</th>
            <th>ACTIONS</th>
          </tr>
        </thead>

        <tbody>

        <% rentals.forEach(r => { %>

          <tr>

            <td>

              <div class="property-info">

                <% if(r.image && r.image.url){ %>

                  <img src="<%= r.image.url %>">

                <% } else { %>

                  <img src="https://placehold.co/80x60">

                <% } %>

                <div>
                  <h4><%= r.name %></h4>
                  <p><%= r.address %></p>
                </div>

              </div>

            </td>

            <td>
              <%= r.type || "Residential" %>
            </td>

            <td>
              <%= r.beds || 0 %> Beds
            </td>

            <td>

              <span class="status-badge occupied">
                Available
              </span>

            </td>

            <td>
              ৳<%= Number(r.rentPrice).toLocaleString() %>
            </td>

            <td>

              <div class="table-actions">

                <a href="/rentals/<%= r._id %>">
                  <i class="bi bi-eye"></i>
                </a>

                <a href="/rentals/<%= r._id %>/edit">
                  <i class="bi bi-pencil"></i>
                </a>

                <form action="/rentals/<%= r._id %>?_method=DELETE"
                      method="POST">

                  <button type="submit">
                    <i class="bi bi-trash"></i>
                  </button>

                </form>

              </div>

            </td>

          </tr>

        <% }) %>

        </tbody>

      </table>

    </div>

  </main>

</div>

</body>
</html>