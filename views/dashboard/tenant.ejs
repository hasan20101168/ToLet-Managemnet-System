<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Tenant Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include("../partials/navbar") %>

<div class="container py-5">

  <h2 class="mb-4">Tenant Dashboard</h2>

  <!-- ACTIVE RENTALS -->
  <div class="card mb-5">
    <div class="card-header">
      Current Rentals
    </div>

    <div class="card-body">

      <% if(rentals.length === 0) { %>

        <p>No approved rentals yet.</p>

      <% } %>

      <% rentals.forEach(rental => { %>

        <div class="border rounded p-3 mb-4">

          <h4><%= rental.name %></h4>

          <p>
            <strong>Address:</strong>
            <%= rental.address %>
          </p>

          <p>
            <strong>Monthly Rent:</strong>
            ৳<%= rental.rentPrice.toLocaleString() %>
          </p>

          <p>
            <strong>Owner:</strong>
            <%= rental.owner.name %>
          </p>

          <!-- DEMO PAYMENT -->
          <form>

            <button
              type="button"
              class="btn btn-success mb-3"
              onclick="alert('Demo payment successful!')"
            >
              Pay Rent
            </button>

          </form>

          <!-- MAINTENANCE -->
          <form
            action="/rentals/tenant/maintenance/<%= rental._id %>"
            method="POST"
          >

            <div class="mb-2">
              <input
                type="text"
                name="title"
                class="form-control"
                placeholder="Maintenance title"
                required
              >
            </div>

            <div class="mb-2">
              <textarea
                name="description"
                class="form-control"
                placeholder="Describe the issue..."
                required
              ></textarea>
            </div>

            <button class="btn btn-warning">
              Request Maintenance
            </button>

          </form>

        </div>

      <% }) %>

    </div>
  </div>

  <!-- MAINTENANCE STATUS -->
  <div class="card">

    <div class="card-header">
      Maintenance Requests
    </div>

    <div class="card-body">

      <% if(maintenanceRequests.length === 0) { %>

        <p>No maintenance requests.</p>

      <% } %>

      <% maintenanceRequests.forEach(req => { %>

        <div class="border rounded p-3 mb-3">

          <h5><%= req.title %></h5>

          <p><%= req.description %></p>

          <p>
            <strong>Property:</strong>
            <%= req.rental.name %>
          </p>

          <span class="
            badge
            <%= req.status === 'completed'
              ? 'bg-success'
              : req.status === 'in-progress'
              ? 'bg-primary'
              : 'bg-warning'
            %>
          ">
            <%= req.status %>
          </span>

        </div>

      <% }) %>

    </div>

  </div>

</div>

</body>
</html>