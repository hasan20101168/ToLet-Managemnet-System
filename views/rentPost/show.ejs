<div class="container mt-4">

  <!-- Title -->
  <h2 class="mb-3"><%= rental.name %></h2>

  <!-- Image -->
  <% if (rental.image && rental.image.url) { %>
    <img src="<%= rental.image.url %>" class="hero-img mb-4">
  <% } else { %>
    <img src="https://via.placeholder.com/900x400?text=No+Image" class="hero-img mb-4">
  <% } %>

  <div class="row">

    <!-- Left Section -->
    <div class="col-lg-8">

      <!-- Address -->
      <p class="text-muted">📍 <%= rental.address %></p>

      <!-- Features -->
      <div class="mb-3">
        <span class="feature-box">🛏 <%= rental.beds || 0 %> Beds</span>
        <span class="feature-box">🛁 <%= rental.baths || 0 %> Baths</span>
        <span class="feature-box">🍽 <%= rental.dining || 0 %> Dining</span>
        <span class="feature-box">🛋 <%= rental.drawing || 0 %> Drawing</span>
        <span class="feature-box">🚗 <%= rental.porch || 0 %> Porch</span>
        <span class="feature-box">📐 <%= rental.squareFeet || 0 %> sqft</span>
      </div>

      <!-- Description -->
      <div class="info-card mb-3">
        <h5>Description</h5>
        <p class="description"><%= rental.description || "No description provided." %></p>
      </div>

      <!-- Availability -->
      <div class="info-card">
        <h6>Available From:</h6>
        <p>
          <%= rental.availableFrom 
              ? new Date(rental.availableFrom).toDateString() 
              : "Not specified" %>
        </p>
      </div>

    </div>

    <!-- Right Section -->
    <div class="col-lg-4">

      <div class="info-card">

        <p class="price">৳ <%= rental.rentPrice %></p>

        <hr>

        <!-- Actions -->
        <a href="/rentals/<%= rental._id %>/edit" class="btn btn-warning w-100 mb-2">
          ✏️ Edit
        </a>

        <form action="/rentals/<%= rental._id %>?_method=DELETE" method="POST">
          <button class="btn btn-danger w-100 mb-2" onclick="return confirm('Delete this rental?')">
            🗑 Delete
          </button>
        </form>

        <a href="/rentals" class="btn btn-secondary w-100">
          ⬅ Back to Listings
        </a>

      </div>

    </div>

  </div>

  <div id="map" style="width: 800px; height: 600px;"></div>

</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const mapToken = '<%-process.env.MAPBOX_TOKEN%>';
  const rental = <%- JSON.stringify(rental) %>
</script>
<script src="/js/showPageMap.js"></script>

</body>
