<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Rental Listings</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <span class="navbar-brand">🏠 To-Let System</span>
    <a href="/rentals/new" class="btn btn-light">+ Add Rental</a>
  </div>
</nav>

<div class="container mt-4">

  <h2 class="mb-4">Available Rentals</h2>

  <div class="row g-4">

    <% rentals.forEach(rental => { %>
      <div class="col-md-4 col-lg-3">
        <div class="card h-100">

          <!-- Image -->
          <% if (rental.image && rental.image.url) { %>
            <img src="<%= rental.image.url %>" class="card-img-top">
          <% } else { %>
            <img src="https://via.placeholder.com/400x200?text=No+Image" class="card-img-top">
          <% } %>

          <div class="card-body d-flex flex-column">

            <h5 class="card-title"><%= rental.name %></h5>

            <p class="text-muted small mb-1">
              📍 <%= rental.address %>
            </p>

            <p class="price mb-2">
              ৳ <%= rental.rentPrice %>
            </p>

            <p class="small text-muted">
              🛏 <%= rental.beds || 0 %> |
              🛁 <%= rental.baths || 0 %> |
              📐 <%= rental.squareFeet || 0 %> sqft
            </p>

            <div class="mt-auto btn-group">

              <a href="/rentals/<%= rental._id %>" class="btn btn-sm btn-primary">View</a>

              <a href="/rentals/<%= rental._id %>/edit" class="btn btn-sm btn-warning">Edit</a>

              <form action="/rentals/<%= rental._id %>?_method=DELETE" method="POST">
                <button class="btn btn-sm btn-danger" onclick="return confirmDelete()">
                  Delete
                </button>
              </form>

            </div>

          </div>
        </div>
      </div>
    <% }) %>

  </div>

</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>


</body>
</html>