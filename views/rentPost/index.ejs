<!DOCTYPE html>
<html class="light" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Properties | ToLet</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Geist:wght@400;600;700;800&display=swap" rel="stylesheet"/>
<script id="tailwind-config">
  tailwind.config = {
    darkMode: "class",
    theme: {
      extend: {
        colors: {
          "tertiary-container": "#bc4800","surface-container": "#eceef0","on-tertiary-container": "#ffede6",
          "on-primary-fixed": "#00174b","on-error-container": "#93000a","surface-container-high": "#e6e8ea",
          "inverse-on-surface": "#eff1f3","surface-container-low": "#f2f4f6","error-container": "#ffdad6",
          "primary-fixed": "#dbe1ff","on-primary-fixed-variant": "#003ea8","on-surface": "#191c1e",
          "on-tertiary": "#ffffff","on-tertiary-fixed-variant": "#7d2d00","background": "#f7f9fb",
          "on-surface-variant": "#434655","secondary-fixed": "#d3e4fe","primary-fixed-dim": "#b4c5ff",
          "surface-bright": "#f7f9fb","tertiary-fixed-dim": "#ffb596","on-primary-container": "#eeefff",
          "surface-container-lowest": "#ffffff","on-error": "#ffffff","tertiary-fixed": "#ffdbcd",
          "secondary-fixed-dim": "#b7c8e1","primary-container": "#2563eb","tertiary": "#943700",
          "inverse-surface": "#2d3133","secondary": "#505f76","outline-variant": "#c3c6d7",
          "inverse-primary": "#b4c5ff","on-primary": "#ffffff","primary": "#004ac6",
          "outline": "#737686","on-background": "#191c1e","on-secondary": "#ffffff",
          "surface": "#f7f9fb","surface-variant": "#e0e3e5","on-tertiary-fixed": "#360f00",
          "on-secondary-fixed-variant": "#38485d","on-secondary-fixed": "#0b1c30",
          "secondary-container": "#d0e1fb","surface-container-highest": "#e0e3e5",
          "on-secondary-container": "#54647a","error": "#ba1a1a","surface-tint": "#0053db","surface-dim": "#d8dadc"
        },
        borderRadius: { DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", full: "9999px" },
        spacing: {
          gutter: "24px","container-max": "1280px","margin-mobile": "16px",
          base: "4px", xl: "48px", sm: "8px", md: "16px", lg: "24px", xs: "4px"
        },
        fontFamily: {
          "headline-md": ["Geist"],"headline-lg-mobile": ["Geist"],"body-md": ["Inter"],
          "headline-sm": ["Geist"],"body-lg": ["Inter"],"label-caps": ["Inter"],
          "headline-lg": ["Geist"],"data-point": ["Geist"],"body-sm": ["Inter"]
        },
        fontSize: {
          "headline-md": ["24px",{lineHeight:"1.3",fontWeight:"600"}],
          "headline-lg-mobile": ["24px",{lineHeight:"1.2",fontWeight:"600"}],
          "body-md": ["16px",{lineHeight:"1.6",fontWeight:"400"}],
          "headline-sm": ["18px",{lineHeight:"1.4",fontWeight:"600"}],
          "body-lg": ["18px",{lineHeight:"1.6",fontWeight:"400"}],
          "label-caps": ["12px",{lineHeight:"1",letterSpacing:"0.05em",fontWeight:"700"}],
          "headline-lg": ["32px",{lineHeight:"1.2",letterSpacing:"-0.02em",fontWeight:"600"}],
          "data-point": ["14px",{lineHeight:"1",fontWeight:"500"}],
          "body-sm": ["14px",{lineHeight:"1.5",fontWeight:"400"}]
        }
      }
    }
  }
</script>
<style>
  .material-symbols-outlined { font-variation-settings: 'FILL' 0,'wght' 400,'GRAD' 0,'opsz' 24; }
  body { background-color: #f7f9fb; }
  input[type="date"]::-webkit-calendar-picker-indicator { opacity: 0.5; cursor: pointer; }
</style>
</head>


<body class="font-body-md text-on-surface">

<!-- ══════════════════════════════════════════
     TOP APP BAR
     The navbar search is wired to submit filterForm
     so it behaves identically to the sidebar search.
════════════════════════════════════════════ -->
 <header class="bg-surface-container-lowest shadow-sm top-0 z-40 sticky">
  <div class="flex justify-between items-center px-gutter py-4 w-full max-w-container-max mx-auto">
    <div class="flex items-center gap-xl">
      <a class="font-headline-md text-headline-md font-bold text-primary tracking-tight" href="/rentals">ToLet</a>
      <nav class="hidden md:flex items-center gap-lg">
        <a class="font-body-md text-body-md text-primary font-bold border-b-2 border-primary pb-1" href="/rentals">Properties</a>
        <a class="font-body-md text-body-md text-on-surface-variant font-medium hover:text-primary transition-all duration-200" href="#">Favorites</a>
      </nav>
    </div>
    <div class="flex items-center gap-md">
      <!-- Navbar search — submits the sidebar filter form so all filters stay in sync -->
      <div class="hidden lg:flex relative items-center">
        <span class="material-symbols-outlined absolute left-3 text-outline">search</span>
        <input
          type="text"
          id="navSearch"
          placeholder="Search properties..."
          value="<%= filters?.search || '' %>"
          class="pl-10 pr-4 py-2 bg-surface-container-low border border-outline-variant/30 rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none text-body-sm w-64"
        />
      </div>
      <% if (currentUser) { %>
      <form action="/logout" method="POST">
  <button
    type="submit"
    class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium bg-error text-on-error hover:opacity-90 transition-opacity shadow-sm"
  >
    <span class="material-symbols-outlined text-[18px]">logout</span>
    Logout
  </button>
</form>
      <% } %>
      
    </div>
  </div>
</header> 

<main class="max-w-container-max mx-auto flex">

  <!-- ══════════════════════════════════════════
       SIDEBAR — real working filter form
  ════════════════════════════════════════════ -->
  <aside class="hidden md:flex flex-col h-[calc(100vh-72px)] w-80 sticky top-[72px] bg-surface-container-low border-r border-outline-variant/30 overflow-y-auto">
    <form method="GET" action="/rentals" id="filterForm" class="flex flex-col gap-md p-md h-full">

      <!-- Always reset to page 1 when applying new filters -->
      <input type="hidden" name="page" value="1">

      <!-- Heading -->
      <div>
        <h2 class="font-headline-sm text-headline-sm font-semibold text-on-surface">Filters</h2>
        <p class="font-body-sm text-body-sm text-on-surface-variant">Refine your search</p>
      </div>

      <!-- ── SEARCH ── -->
      <div class="flex flex-col gap-xs">
        <label for="sidebarSearch" class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-1">
          <span class="material-symbols-outlined text-[15px]">search</span> SEARCH
        </label>
        <input
          type="text"
          name="search"
          id="sidebarSearch"
          placeholder="Name or address…"
          value="<%= filters?.search || '' %>"
          class="w-full px-3 py-2 bg-surface-container-lowest border border-outline-variant/40 rounded-lg text-body-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none"
        />
      </div>

      <!-- ── PRICE RANGE ── -->
      <div class="flex flex-col gap-xs">
        <label class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-1">
          <span class="material-symbols-outlined text-[15px]">payments</span> PRICE RANGE
        </label>
        <div class="flex gap-sm">
          <input
            type="number"
            name="minPrice"
            placeholder="Min ৳"
            value="<%= filters?.minPrice || '' %>"
            min="0"
            class="w-1/2 px-3 py-2 bg-surface-container-lowest border border-outline-variant/40 rounded-lg text-body-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none"
          />
          <input
            type="number"
            name="maxPrice"
            placeholder="Max ৳"
            value="<%= filters?.maxPrice || '' %>"
            min="0"
            class="w-1/2 px-3 py-2 bg-surface-container-lowest border border-outline-variant/40 rounded-lg text-body-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none"
          />
        </div>
      </div>

      <!-- ── BEDROOMS ── -->
      <div class="flex flex-col gap-xs">
        <label for="bedsFilter" class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-1">
          <span class="material-symbols-outlined text-[15px]">bed</span> BEDROOMS
        </label>
        <select
          name="beds"
          id="bedsFilter"
          class="w-full px-3 py-2 bg-surface-container-lowest border border-outline-variant/40 rounded-lg text-body-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none"
        >
          <option value="">Any beds</option>
          <option value="1" <%= filters?.beds == 1 ? 'selected' : '' %>>1+ beds</option>
          <option value="2" <%= filters?.beds == 2 ? 'selected' : '' %>>2+ beds</option>
          <option value="3" <%= filters?.beds == 3 ? 'selected' : '' %>>3+ beds</option>
          <option value="4" <%= filters?.beds == 4 ? 'selected' : '' %>>4+ beds</option>
        </select>
      </div>

      <!-- ── AVAILABLE FROM ── -->
      <div class="flex flex-col gap-xs">
        <label for="availableFrom" class="font-label-caps text-label-caps text-on-surface-variant flex items-center gap-1">
          <span class="material-symbols-outlined text-[15px]">calendar_today</span> AVAILABLE FROM
        </label>
        <input
          type="date"
          name="availableFrom"
          id="availableFrom"
          value="<%= filters?.availableFrom || '' %>"
          class="w-full px-3 py-2 bg-surface-container-lowest border border-outline-variant/40 rounded-lg text-body-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none"
        />
      </div>

      <!-- ── ACTIVE FILTER BADGE ── -->
      <%
        var activeCount = 0;
        if (filters && filters.search)        activeCount++;
        if (filters && filters.minPrice)      activeCount++;
        if (filters && filters.maxPrice)      activeCount++;
        if (filters && filters.beds)          activeCount++;
        if (filters && filters.availableFrom) activeCount++;
      %>
      <% if (activeCount > 0) { %>
      <div class="flex items-center gap-2 px-3 py-2 bg-primary/10 rounded-lg">
        <span class="material-symbols-outlined text-primary text-[16px]">filter_alt</span>
        <span class="font-body-sm text-body-sm text-primary font-medium">
          <%= activeCount %> active filter<%= activeCount !== 1 ? 's' : '' %>
        </span>
      </div>
      <% } %>

      <!-- Spacer -->
      <div class="flex-1"></div>

      <!-- ── ACTION BUTTONS ── -->
      <div class="flex flex-col gap-sm pt-lg border-t border-outline-variant/20">
        <button
          type="submit"
          class="w-full bg-primary text-on-primary font-bold py-3 rounded-lg hover:opacity-90 transition-opacity shadow-sm flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined text-[18px]">search</span>
          Apply Filters
        </button>
        <a
          href="/rentals"
          class="w-full text-center py-2 rounded-lg border border-outline-variant text-on-surface-variant font-body-sm text-body-sm hover:bg-surface-container transition-colors block"
        >
          Reset filters
        </a>
      </div>

    </form>
  </aside>

  <!-- ══════════════════════════════════════════
       MAIN CONTENT
  ════════════════════════════════════════════ -->
  <section class="flex-1 p-gutter bg-background">

    <!-- Page header -->
    <header class="mb-lg flex justify-between items-end flex-wrap gap-sm">
      <div>
        <h1 class="font-headline-lg text-headline-lg text-on-surface">Available Properties</h1>
        <p class="font-body-md text-body-md text-on-surface-variant">
          Showing <%= rentals.length %> of <%= totalRentals %> premium listing<%= totalRentals !== 1 ? 's' : '' %>
          <% if (activeCount > 0) { %><span class="text-primary font-medium"> (filtered)</span><% } %>
        </p>
      </div>
      <div class="flex gap-sm items-center">
        <!-- Mobile filter toggle (shows filter form inline on small screens) -->
        <button
          class="md:hidden flex items-center gap-2 px-4 py-2 border border-outline-variant rounded-full text-body-sm font-medium hover:bg-surface-container transition-colors"
          onclick="document.getElementById('mobileFilters').classList.toggle('hidden')"
        >
          <span class="material-symbols-outlined text-[18px]">tune</span>
          Filters<% if (activeCount > 0) { %> (<%= activeCount %>)<% } %>
        </button>
        <button class="flex items-center gap-2 px-4 py-2 border border-outline-variant rounded-full text-body-sm font-medium hover:bg-surface-container transition-colors">
          <span class="material-symbols-outlined text-[18px]">sort</span>
          Sort by: Newest
        </button>
      </div>
    </header>

    <!-- Mobile filters (hidden by default, toggled above) -->
    <div id="mobileFilters" class="hidden md:hidden mb-lg">
      <form method="GET" action="/rentals" class="bg-surface-container-lowest border border-outline-variant/30 rounded-xl p-md flex flex-col gap-md">
        <input type="hidden" name="page" value="1">
        <input type="text" name="search" placeholder="Search by name or address…" value="<%= filters?.search || '' %>"
          class="w-full px-3 py-2 border border-outline-variant/40 rounded-lg text-body-sm outline-none focus:ring-2 focus:ring-primary/20"/>
        <div class="flex gap-sm">
          <input type="number" name="minPrice" placeholder="Min ৳" value="<%= filters?.minPrice || '' %>" min="0"
            class="w-1/2 px-3 py-2 border border-outline-variant/40 rounded-lg text-body-sm outline-none focus:ring-2 focus:ring-primary/20"/>
          <input type="number" name="maxPrice" placeholder="Max ৳" value="<%= filters?.maxPrice || '' %>" min="0"
            class="w-1/2 px-3 py-2 border border-outline-variant/40 rounded-lg text-body-sm outline-none focus:ring-2 focus:ring-primary/20"/>
        </div>
        <select name="beds" class="w-full px-3 py-2 border border-outline-variant/40 rounded-lg text-body-sm outline-none focus:ring-2 focus:ring-primary/20">
          <option value="">Any beds</option>
          <option value="1" <%= filters?.beds == 1 ? 'selected' : '' %>>1+ beds</option>
          <option value="2" <%= filters?.beds == 2 ? 'selected' : '' %>>2+ beds</option>
          <option value="3" <%= filters?.beds == 3 ? 'selected' : '' %>>3+ beds</option>
          <option value="4" <%= filters?.beds == 4 ? 'selected' : '' %>>4+ beds</option>
        </select>
        <input type="date" name="availableFrom" value="<%= filters?.availableFrom || '' %>"
          class="w-full px-3 py-2 border border-outline-variant/40 rounded-lg text-body-sm outline-none focus:ring-2 focus:ring-primary/20"/>
        <div class="flex gap-sm">
          <button type="submit" class="flex-1 bg-primary text-on-primary font-bold py-2 rounded-lg hover:opacity-90 transition-opacity">Apply</button>
          <a href="/rentals" class="flex-1 text-center py-2 border border-outline-variant rounded-lg text-on-surface-variant text-body-sm hover:bg-surface-container transition-colors">Reset</a>
        </div>
      </form>
    </div>

    <!-- Property Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-lg">

      <% rentals.forEach(function(rental, index) { %>
      <article class="group bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_4px_6px_-1px_rgb(0_0_0/0.05),0_2px_4px_-2px_rgb(0_0_0/0.05)] hover:shadow-[0_10px_15px_-3px_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300">

        <div class="relative aspect-[3/2] overflow-hidden">
          <% if (rental.image && rental.image.url) { %>
            <a href="/rentals/<%= rental._id %>" class="btn-action btn-view">
            <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                 src="<%= rental.image.url %>" alt="<%= rental.name %>"/>
            </a>
          <% } else { %>
            <div class="w-full h-full bg-surface-container-high flex items-center justify-center">
              <span class="material-symbols-outlined text-outline" style="font-size:48px">home</span>
            </div>
          <% } %>

          <% if (index === 0) { %>
            <div class="absolute top-4 left-4 bg-surface-container-lowest/90 backdrop-blur px-3 py-1 rounded-full text-label-caps font-bold text-primary">NEW LISTING</div>
          <% } else if (index === 1) { %>
            <div class="absolute top-4 left-4 bg-surface-container-lowest/90 backdrop-blur px-3 py-1 rounded-full text-label-caps font-bold text-tertiary">FEATURED</div>
          <% } %>

          <button class="absolute top-4 right-4 bg-white/20 hover:bg-white/40 backdrop-blur p-2 rounded-full text-white transition-colors">
            <span class="material-symbols-outlined">favorite</span>
          </button>
        </div>

        <div class="p-lg">
          <div class="flex justify-between items-start mb-2">
            <h3 class="font-headline-sm text-headline-sm text-on-surface"><%= rental.name %></h3>
            <span class="font-headline-sm text-headline-sm text-primary">
              $<%= rental.rentPrice.toLocaleString() %><span class="text-body-sm font-normal text-on-surface-variant">/mo</span>
            </span>
          </div>
          <p class="font-body-sm text-body-sm text-on-surface-variant mb-4"><%= rental.address %></p>
          <div class="flex items-center gap-md border-t border-outline-variant/10 pt-4">
            <div class="flex items-center gap-1 text-on-surface-variant">
              <span class="material-symbols-outlined text-outline">bed</span>
              <span class="font-data-point text-data-point">
                <% if (rental.beds && rental.beds > 0) { %><%= rental.beds %> Bed<%= rental.beds !== 1 ? 's' : '' %><% } else { %>Studio<% } %>
              </span>
            </div>
            <div class="flex items-center gap-1 text-on-surface-variant">
              <span class="material-symbols-outlined text-outline">bathtub</span>
              <span class="font-data-point text-data-point"><%= rental.baths %> Bath<%= rental.baths !== 1 ? 's' : '' %></span>
            </div>
            <div class="flex items-center gap-1 text-on-surface-variant">
              <span class="material-symbols-outlined text-outline">square_foot</span>
              <span class="font-data-point text-data-point"><%= rental.squareFeet ? rental.squareFeet.toLocaleString() + ' sqft' : 'N/A' %></span>
            </div>
          </div>
        </div>

      </article>
      <% }) %>

      <!-- Empty state -->
      <% if (rentals.length === 0) { %>
      <div class="col-span-full flex flex-col items-center justify-center py-xl text-on-surface-variant gap-md">
        <span class="material-symbols-outlined" style="font-size:64px">search_off</span>
        <p class="font-headline-sm text-headline-sm">No properties found</p>
        <p class="font-body-sm text-body-sm">Try adjusting your filters or <a href="/rentals" class="text-primary underline">reset them</a>.</p>
      </div>
      <% } %>

    </div>

    <!-- ══════════════════════════════════════════
         PAGINATION
         qBase preserves all active filter params
         so clicking page 2 while filtering keeps
         search/minPrice/beds/etc in the URL.
    ════════════════════════════════════════════ -->
    <% if (totalPages > 1) { %>
    <%
      var filterParams = Object.assign({}, filters);
      delete filterParams.page;
      var filterString = Object.keys(filterParams)
        .filter(function(k) { return filterParams[k] !== '' && filterParams[k] !== undefined; })
        .map(function(k) { return encodeURIComponent(k) + '=' + encodeURIComponent(filterParams[k]); })
        .join('&');
      var qBase = filterString ? '?' + filterString + '&' : '?';
    %>
    <div class="flex justify-center items-center gap-1 mt-xl flex-wrap">

      <% if (currentPage > 1) { %>
        <a href="<%= qBase %>page=<%= currentPage - 1 %>"
           class="p-2 rounded-full hover:bg-surface-container transition-colors text-on-surface-variant">
          <span class="material-symbols-outlined">chevron_left</span>
        </a>
      <% } else { %>
        <span class="p-2 rounded-full text-outline-variant cursor-not-allowed opacity-40">
          <span class="material-symbols-outlined">chevron_left</span>
        </span>
      <% } %>

      <%
        var pages = [];
        for (var p = 1; p <= totalPages; p++) {
          if (p === 1 || p === totalPages || (p >= currentPage - 1 && p <= currentPage + 1)) {
            pages.push(p);
          } else if (pages[pages.length - 1] !== '...') {
            pages.push('...');
          }
        }
      %>

      <% pages.forEach(function(p) { %>
        <% if (p === '...') { %>
          <span class="w-10 h-10 flex items-center justify-center text-on-surface-variant select-none">…</span>
        <% } else if (p === currentPage) { %>
          <span class="w-10 h-10 flex items-center justify-center rounded-full bg-primary text-on-primary font-bold text-body-sm"><%= p %></span>
        <% } else { %>
          <a href="<%= qBase %>page=<%= p %>"
             class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container transition-colors text-on-surface font-medium text-body-sm">
            <%= p %>
          </a>
        <% } %>
      <% }) %>

      <% if (currentPage < totalPages) { %>
        <a href="<%= qBase %>page=<%= currentPage + 1 %>"
           class="p-2 rounded-full hover:bg-surface-container transition-colors text-on-surface-variant">
          <span class="material-symbols-outlined">chevron_right</span>
        </a>
      <% } else { %>
        <span class="p-2 rounded-full text-outline-variant cursor-not-allowed opacity-40">
          <span class="material-symbols-outlined">chevron_right</span>
        </span>
      <% } %>

    </div>
    <p class="text-center font-body-sm text-body-sm text-on-surface-variant mt-md">
      Page <%= currentPage %> of <%= totalPages %>
    </p>
    <% } %>

  </section>
</main>

<!-- Footer -->
<footer class="bg-surface-container-highest border-t border-outline-variant/20">
  <div class="flex flex-col md:flex-row justify-between items-center px-gutter py-xl w-full max-w-container-max mx-auto mt-xl">
    <div class="mb-md md:mb-0">
      <span class="font-headline-sm text-headline-sm font-bold text-primary">To-Let</span>
      <p class="text-on-surface-variant font-body-sm text-body-sm mt-2 max-w-xs">
        Connecting discerning renters with the Bangladesh's most exceptional living spaces since 2026.
      </p>
    </div>
    <div class="flex flex-col items-center md:items-end gap-md">
      <div class="flex gap-lg">
        <a class="text-on-secondary-container font-body-sm text-body-sm hover:text-primary transition-colors" href="#">Privacy Policy</a>
        <a class="text-on-secondary-container font-body-sm text-body-sm hover:text-primary transition-colors" href="#">Terms of Service</a>
        <a class="text-on-secondary-container font-body-sm text-body-sm hover:text-primary transition-colors" href="#">Support</a>
        <a class="text-on-secondary-container font-body-sm text-body-sm hover:text-primary transition-colors" href="#">Contact Us</a>
      </div>
      <p class="text-on-surface-variant font-body-sm text-body-sm">© 2026 To-Let Marketplace. All rights reserved.</p>
    </div>
  </div>
</footer>

<!-- ══════════════════════════════════════════
     JS: sync navbar search → sidebar form field
     so both inputs always submit the same form.
════════════════════════════════════════════ -->
<script>
  (function () {
    var navInput     = document.getElementById('navSearch');
    var sidebarInput = document.getElementById('sidebarSearch');
    var filterForm   = document.getElementById('filterForm');

    if (!navInput || !sidebarInput || !filterForm) return;

    // Keep navbar input in sync with sidebar while typing
    navInput.addEventListener('input', function () {
      sidebarInput.value = navInput.value;
    });

    // Submit the sidebar form when user presses Enter in the navbar search
    navInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        sidebarInput.value = navInput.value;
        filterForm.submit();
      }
    });
  })();
</script>

</body>
</html>
