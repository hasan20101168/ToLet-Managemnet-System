<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Rental Listings</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <!-- SAME CSS AS OWNER -->
  <link rel="stylesheet" href="/css/indexPage.css">
</head>

<body>
<%- include("../partials/navbar") %>

<!-- HERO -->
<header class="hero">
  <div class="container">
    <span class="badge-soft mb-3 d-inline-block">
      <i class="bi bi-houses-fill me-1"></i>
      <%= rentals.length %> properties available
    </span>

    <h1>Find your next home</h1>
    <p>Browse curated rental listings with verified pricing, photos and amenities.</p>
  </div>
</header>

<!-- 🔍 FILTER (UI UPDATED, LOGIC SAME) -->
<div class="filter-wrap">
  <div class="container">
    <div class="filter-box">

      <div class="filter-header">
        <i class="bi bi-sliders"></i>
        <span>Filter properties</span>
      </div>

      <form method="GET" action="/rentals" class="filter-row">

        <!-- keep pagination reset -->
        <input type="hidden" name="page" value="1">

        <!-- SEARCH -->
        <div class="filter-item search">
          <i class="bi bi-search"></i>
          <input 
            type="text" 
            name="search"
            placeholder="Search by name..."
            value="<%= filters?.search || '' %>"
          >
        </div>

        <!-- LOCATION (reuse search if needed or keep placeholder) -->
        <input 
          type="text" 
          name="location"
          class="filter-item"
          placeholder="All locations"
          value="<%= filters?.location || '' %>"
        >

        <!-- TYPE (optional, UI only if not used) -->
        <select class="filter-item" name="type">
          <option value="">All types</option>
        </select>

        <!-- BEDS -->
        <select name="beds" class="filter-item">
          <option value="">Any beds</option>
          <option value="1" <%= filters?.beds == 1 ? 'selected' : '' %>>1+</option>
          <option value="2" <%= filters?.beds == 2 ? 'selected' : '' %>>2+</option>
          <option value="3" <%= filters?.beds == 3 ? 'selected' : '' %>>3+</option>
        </select>

        <!-- MAX PRICE -->
        <input 
          type="number" 
          name="maxPrice"
          class="filter-item"
          placeholder="Max ৳"
          value="<%= filters?.maxPrice || '' %>"
        >

        <!-- SUBMIT -->
        <button class="btn-action btn-view">Search</button>

        <!-- RESET -->
        <a href="/rentals" class="reset-btn">Reset filters</a>

      </form>
    </div>
  </div>
</div>

<!-- MAIN -->
<main class="main-wrap">
  <div class="container">

    <!-- INFO -->
    <p class="text-muted mb-3">
      Page <strong><%= currentPage %></strong> of <strong><%= totalPages %></strong>
    </p>

    <!-- GRID -->
    <div class="rental-grid">

      <% if (rentals.length === 0) { %>
        <div class="empty-card">
          <i class="bi bi-house"></i>
          <p>No rentals found.</p>
        </div>
      <% } %>

      <% rentals.forEach(r => { %>
        <article class="rental-card">

          <div class="rental-media">
            <% if (r.image && r.image.url) { %>
              <img src="<%= r.image.url %>" alt="<%= r.name %>">
            <% } else { %>
              <div class="no-image">No image</div>
            <% } %>

            <span class="chip-price">৳<%= Number(r.rentPrice).toLocaleString() %></span>
          </div>

          <div class="rental-body">
            <h3 class="rental-title"><%= r.name %></h3>

            <p class="rental-address">
              <i class="bi bi-geo-alt-fill"></i>
              <%= r.address %>
            </p>

            <div class="rental-meta">
              <span><i class="bi bi-door-closed-fill"></i> <%= r.beds || 0 %></span>
              <span><i class="bi bi-droplet-fill"></i> <%= r.baths || 0 %></span>
              <span><i class="bi bi-rulers"></i> <%= r.squareFeet || 0 %> sqft</span>
            </div>

            <div class="rental-actions">
              <a href="/rentals/<%= r._id %>" class="btn-action btn-view">
                <i class="bi bi-eye-fill"></i> View
              </a>
            </div>
          </div>

        </article>
      <% }) %>

    </div>

    <!-- PAGINATION -->
    <% if (totalPages > 1) { %>
      <nav class="mt-5">
        <ul class="pagination justify-content-center">

          <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
            <a class="page-link"
              href="?<%= new URLSearchParams({...filters, page: currentPage - 1}).toString() %>">
              Previous
            </a>
          </li>

          <% for(let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
              <a class="page-link"
                href="?<%= new URLSearchParams({...filters, page: i}).toString() %>">
                <%= i %>
              </a>
            </li>
          <% } %>

          <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
            <a class="page-link"
              href="?<%= new URLSearchParams({...filters, page: currentPage + 1}).toString() %>">
              Next
            </a>
          </li>

        </ul>
      </nav>
    <% } %>

  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>